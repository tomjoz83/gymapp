# Dependencies
node_modules/

# Runtime logs
*.log
server.log

# Runtime data — lives outside the repo on the VPS (see STORE_PATH/ARCHIVE_PATH).
# Not synced via git so the app can write freely without merge conflicts.
data.json
archive.json

# Store write artifacts (atomic-save temp + backup)
*.json.tmp
*.json.bak

# Auth secret — never commit
.auth-token

# OS / editor cruft
.DS_Store
*.swp
